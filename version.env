SHUTTLE_PROFILE="${SHUTTLE_PROFILE:-prod}"

SPM_PACKAGE_NAME="Shuttle"
SPM_APP_PRODUCT="ShuttleApp"
CLI_PRODUCT="shuttle"
VERSION="1.1.0"
BUILD_NUMBER="${BUILD_NUMBER:-$(date -u +%Y%m%d%H%M)}"
MIN_MACOS="14.0"
APP_CATEGORY="public.app-category.developer-tools"
APP_ICON_MASTER_SVG="Packaging/AppIcon.master.svg"
EMBED_GHOSTTY_RESOURCES="${EMBED_GHOSTTY_RESOURCES:-auto}"
GHOSTTY_APP_RESOURCES_DIR="${GHOSTTY_APP_RESOURCES_DIR:-/Applications/Ghostty.app/Contents/Resources}"

case "$SHUTTLE_PROFILE" in
  dev)
    APP_NAME="Shuttle Dev"
    BUNDLE_ID="com.pascaldeladurantaye.shuttle.dev"
    SHUTTLE_CONFIG_DIR_NAME="shuttle-dev"
    SHUTTLE_APP_SUPPORT_NAME="Shuttle Dev"
    SHUTTLE_DEFAULT_SESSION_ROOT="~/Workspaces-Dev"
    DIST_DIR="${DIST_DIR:-dist/macos-dev}"
    ;;
  *)
    SHUTTLE_PROFILE="prod"
    APP_NAME="Shuttle"
    BUNDLE_ID="com.pascaldeladurantaye.shuttle"
    SHUTTLE_CONFIG_DIR_NAME="shuttle"
    SHUTTLE_APP_SUPPORT_NAME="Shuttle"
    SHUTTLE_DEFAULT_SESSION_ROOT="~/Workspaces"
    DIST_DIR="${DIST_DIR:-dist/macos}"
    ;;
esac

SHUTTLE_DEFAULT_TRIES_ROOT="~/src/tries"
SHUTTLE_DEFAULT_CONFIG_DIR="$HOME/.config/$SHUTTLE_CONFIG_DIR_NAME"
SHUTTLE_DEFAULT_APP_SUPPORT_DIR="$HOME/Library/Application Support/$SHUTTLE_APP_SUPPORT_NAME"
SHUTTLE_DEFAULT_PREFERENCES_PLIST="$HOME/Library/Preferences/${BUNDLE_ID}.plist"
SHUTTLE_DEFAULT_SAVED_STATE_DIR="$HOME/Library/Saved Application State/${BUNDLE_ID}.savedState"
SHUTTLE_DEFAULT_CACHE_DIR="$HOME/Library/Caches/${BUNDLE_ID}"
